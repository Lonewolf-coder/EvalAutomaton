{
  "manifest_id": "medical-appointment-basic-v1",
  "manifest_version": "1.0",
  "assessment_name": "Medical Appointment Bot — Basic Assessment",
  "assessment_type": "medical",
  "description": "Evaluates a candidate's medical appointment chatbot built on Kore.ai XO Platform. Tests booking, retrieval, modification, cancellation, and FAQ capabilities.",
  "webhook_url": "",
  "mock_api_base_url": "",
  "conversation_starter": "Hi",
  "tasks": [
    {
      "task_id": "task1",
      "task_name": "Welcome Message",
      "pattern": "CREATE",
      "dialog_name": "Welcome",
      "dialog_name_policy": "contains",
      "required_entities": [],
      "required_nodes": [
        { "node_type": "message", "label": "Welcome greeting message node", "required": true }
      ],
      "required_greeting_text": "Welcome",
      "required_menu_items": ["book", "appointment", "retrieve", "modify", "cancel", "FAQ"],
      "conversation_starter": "Hi",
      "weight": 0.5
    },
    {
      "task_id": "task2_booking1",
      "task_name": "Book Appointment — Happy Path",
      "pattern": "CREATE",
      "dialog_name": "Book Appointment",
      "dialog_name_policy": "contains",
      "required_entities": [
        {
          "entity_key": "patientName",
          "semantic_hint": "patient's full name",
          "value_pool": ["John Smith", "Sarah Johnson", "Michael Chen"],
          "validation_required": true,
          "validation_description": "Must contain first and last name"
        },
        {
          "entity_key": "contactNumber",
          "semantic_hint": "contact phone number",
          "value_pool": ["9876543210", "8765432109", "7654321098"],
          "validation_required": true,
          "validation_description": "Must be a valid phone number"
        },
        {
          "entity_key": "doctorType",
          "semantic_hint": "type of doctor or specialist",
          "value_pool": ["General Physician", "Dermatologist", "Cardiologist"]
        },
        {
          "entity_key": "preferredDate",
          "semantic_hint": "preferred appointment date",
          "value_pool": ["2026-03-15", "2026-03-20", "2026-04-01"]
        },
        {
          "entity_key": "preferredTime",
          "semantic_hint": "preferred appointment time",
          "value_pool": ["10:00 AM", "2:00 PM", "4:30 PM"]
        },
        {
          "entity_key": "reasonForVisit",
          "semantic_hint": "reason for the appointment",
          "value_pool": ["Annual checkup", "Follow-up consultation", "Skin rash evaluation"]
        }
      ],
      "required_nodes": [
        { "node_type": "aiassist", "label": "Agent Node required for entity handling", "required": true },
        { "node_type": "service", "label": "POST service node for booking creation", "service_method": "POST", "required": true },
        { "node_type": "entity", "label": "Entity collection nodes", "required": true },
        { "node_type": "prompt", "label": "Booking summary prompt", "required": false }
      ],
      "state_assertion": {
        "enabled": true,
        "verify_endpoint": "",
        "filter_field": "contactNumber",
        "field_assertions": {
          "patientName": "patientName",
          "contactNumber": "contactNumber",
          "doctorType": "doctorType",
          "preferredDate": "preferredDate",
          "preferredTime": "preferredTime"
        }
      },
      "record_alias": "Booking1",
      "weight": 1.0
    },
    {
      "task_id": "task2_booking2",
      "task_name": "Book Appointment — Amendment Edge Case",
      "pattern": "CREATE_WITH_AMENDMENT",
      "dialog_name": "Book Appointment",
      "dialog_name_policy": "contains",
      "required_entities": [
        {
          "entity_key": "patientName",
          "semantic_hint": "patient's full name",
          "value_pool": ["Emily Davis", "Robert Wilson", "Lisa Martinez"]
        },
        {
          "entity_key": "contactNumber",
          "semantic_hint": "contact phone number",
          "value_pool": ["6543210987", "5432109876", "4321098765"]
        },
        {
          "entity_key": "doctorType",
          "semantic_hint": "type of doctor",
          "value_pool": ["Orthopedic", "ENT Specialist", "Neurologist"]
        },
        {
          "entity_key": "preferredDate",
          "semantic_hint": "preferred date",
          "value_pool": ["2026-03-25", "2026-04-05", "2026-04-10"]
        },
        {
          "entity_key": "preferredTime",
          "semantic_hint": "preferred time",
          "value_pool": ["11:00 AM", "3:00 PM", "5:00 PM"]
        },
        {
          "entity_key": "reasonForVisit",
          "semantic_hint": "reason for visit",
          "value_pool": ["Back pain", "Hearing check", "Headache evaluation"]
        }
      ],
      "required_nodes": [
        { "node_type": "aiassist", "label": "Agent Node required for amendment handling", "required": true }
      ],
      "amendment_config": {
        "target_entity": "contactNumber",
        "amendment_utterance_template": "Actually, change the contact number to {amended_value}",
        "amended_value_pool": ["1111111111", "2222222222", "3333333333"]
      },
      "state_assertion": {
        "enabled": true,
        "verify_endpoint": "",
        "filter_field": "contactNumber",
        "field_assertions": {
          "patientName": "patientName",
          "contactNumber": "contactNumber"
        }
      },
      "record_alias": "Booking2",
      "co_reference_test": true,
      "weight": 1.0
    },
    {
      "task_id": "task3_retrieve",
      "task_name": "Get Appointment Details",
      "pattern": "RETRIEVE",
      "dialog_name": "Get Appointment",
      "dialog_name_policy": "contains",
      "required_entities": [
        {
          "entity_key": "contactNumber",
          "semantic_hint": "contact number for lookup",
          "value_pool": []
        }
      ],
      "required_nodes": [
        { "node_type": "service", "label": "GET service node for retrieval", "service_method": "GET", "required": true },
        { "node_type": "entity", "label": "Contact number entity node", "required": true }
      ],
      "cross_task_refs": {
        "lookup": {
          "source_task_id": "task2_booking1",
          "source_record_alias": "Booking1",
          "source_field": "contactNumber"
        }
      },
      "state_assertion": {
        "enabled": true,
        "verify_endpoint": "",
        "filter_field": "contactNumber",
        "field_assertions": {
          "contactNumber": "contactNumber"
        }
      },
      "weight": 1.0
    },
    {
      "task_id": "task3_edge",
      "task_name": "Get Appointment — Invalid Number",
      "pattern": "EDGE_CASE",
      "dialog_name": "Get Appointment",
      "dialog_name_policy": "contains",
      "required_entities": [],
      "required_nodes": [],
      "negative_tests": [
        {
          "invalid_value_pool": ["0000000000", "invalid", "9999999999"],
          "expected_error_pattern": "not found|no record|does not exist|couldn't find",
          "requires_re_entry_prompt": true
        }
      ],
      "cross_task_refs": {
        "lookup": {
          "source_task_id": "task2_booking1",
          "source_record_alias": "Booking1",
          "source_field": "contactNumber"
        }
      },
      "weight": 0.5
    },
    {
      "task_id": "task4_modify",
      "task_name": "Modify Appointment Details",
      "pattern": "MODIFY",
      "dialog_name": "Modify Appointment",
      "dialog_name_policy": "contains",
      "required_entities": [
        {
          "entity_key": "contactNumber",
          "semantic_hint": "contact number for lookup",
          "value_pool": []
        }
      ],
      "required_nodes": [
        { "node_type": "service", "label": "GET service node (retrieve before modify)", "service_method": "GET", "required": true },
        { "node_type": "service", "label": "PUT/PATCH service node for modification", "service_method": "PUT", "required": true }
      ],
      "cross_task_refs": {
        "lookup": {
          "source_task_id": "task2_booking1",
          "source_record_alias": "Booking1",
          "source_field": "contactNumber"
        }
      },
      "modifiable_fields": ["preferredDate", "preferredTime", "doctorType"],
      "modified_value_pool": {
        "preferredDate": ["2026-04-15", "2026-04-20"],
        "preferredTime": ["9:00 AM", "6:00 PM"],
        "doctorType": ["Pediatrician", "Ophthalmologist"]
      },
      "state_assertion": {
        "enabled": true,
        "verify_endpoint": "",
        "filter_field": "contactNumber",
        "field_assertions": {
          "contactNumber": "contactNumber"
        }
      },
      "weight": 1.0
    },
    {
      "task_id": "task4_cancel",
      "task_name": "Cancel Booking 2",
      "pattern": "DELETE",
      "dialog_name": "Modify Appointment",
      "dialog_name_policy": "contains",
      "required_entities": [],
      "required_nodes": [
        { "node_type": "service", "label": "DELETE service node for cancellation", "service_method": "DELETE", "required": true }
      ],
      "cross_task_refs": {
        "lookup": {
          "source_task_id": "task2_booking2",
          "source_record_alias": "Booking2",
          "source_field": "contactNumber"
        }
      },
      "state_assertion": {
        "enabled": true,
        "verify_endpoint": "",
        "filter_field": "contactNumber",
        "field_assertions": {},
        "expect_deletion": true
      },
      "weight": 1.0
    }
  ],
  "faq_config": {
    "required_faqs": [
      {
        "primary_question": "What are your working hours?",
        "ground_truth_answer": "Our clinic is open Monday to Friday from 9 AM to 6 PM, and Saturday from 9 AM to 1 PM.",
        "required_keywords": ["Monday", "Friday", "9 AM", "6 PM"],
        "alternate_questions": [
          "When is the clinic open?",
          "What time do you open and close?"
        ]
      },
      {
        "primary_question": "Do you accept insurance?",
        "ground_truth_answer": "Yes, we accept most major insurance providers. Please bring your insurance card to your appointment.",
        "required_keywords": ["insurance", "accept"],
        "alternate_questions": [
          "Can I use my health insurance?",
          "Which insurance plans do you take?"
        ]
      },
      {
        "primary_question": "How do I cancel my appointment?",
        "ground_truth_answer": "You can cancel your appointment by providing your contact number. We request at least 24 hours notice for cancellations.",
        "required_keywords": ["cancel", "contact number"],
        "alternate_questions": [
          "I need to cancel my visit",
          "How to cancel a booking?"
        ]
      }
    ],
    "min_alternate_questions": 2,
    "semantic_similarity_threshold": 0.80
  },
  "compliance_checks": [
    {
      "check_id": "compliance_dialoggpt",
      "label": "DialogGPT is enabled",
      "cbm_field": "dialogGPTSettings[0].dialogGPTLLMConfig.enable",
      "required_state": "enabled",
      "critical": true,
      "tooltip": "DialogGPT must be enabled for the Agent Node to function correctly."
    },
    {
      "check_id": "compliance_language",
      "label": "Default language is English",
      "cbm_field": "default_language",
      "required_state": "present",
      "critical": false,
      "tooltip": "The bot should have English as its default language."
    }
  ],
  "scoring_config": {
    "cbm_structural_weight": 0.40,
    "webhook_functional_weight": 0.40,
    "compliance_weight": 0.10,
    "faq_weight": 0.10,
    "pass_threshold": 0.70
  },
  "state_seeding_config": {
    "enabled": true,
    "schema_validation": true,
    "seed_endpoint": ""
  },
  "tooltips": [
    { "node_type": "aiassist", "text": "Agent Node — enables LLM-powered entity handling and amendment support." },
    { "node_type": "service", "text": "Service Node — makes API calls (GET, POST, PUT, DELETE) to external services." },
    { "node_type": "entity", "text": "Entity Node — collects a specific piece of information from the user." },
    { "node_type": "message", "text": "Message Node — displays a message to the user." },
    { "node_type": "confirmation", "text": "Confirmation Node — asks the user to confirm before proceeding." },
    { "node_type": "form", "text": "Form Node — collects multiple pieces of information in a structured form." }
  ],
  "created_by": "GovernIQ Admin",
  "notes": "Medical Appointment Bot basic assessment manifest. Covers booking, retrieval, modification, cancellation, and FAQs."
}
