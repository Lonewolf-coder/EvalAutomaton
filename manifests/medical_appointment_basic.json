  "assignment_brief": {
    "scenario_title": "Medical Appointment Bot",
    "scenario_description": "Build a conversational bot that allows patients to book, retrieve, modify, and cancel medical appointments via a Kore.ai XO Platform bot connected to a REST mock API.",
    "what_to_build": [
      "Welcome dialog with a main menu",
      "Book Appointment dialog (collects patient name, contact number, doctor type, date, time, reason)",
      "Get Appointment dialog (retrieves by contact number)",
      "Modify Appointment dialog (updates date, time, or doctor type)",
      "Cancel Appointment flow (deletes by contact number)",
      "FAQ knowledge task covering working hours, insurance, and cancellation policy"
    ],
    "entities_to_collect": [
      {"name": "patientName", "description": "Patient full name (first + last)"},
      {"name": "contactNumber", "description": "10-digit phone number (primary key)"},
      {"name": "doctorType", "description": "Type of doctor or specialist"},
      {"name": "preferredDate", "description": "Appointment date (YYYY-MM-DD)"},
      {"name": "preferredTime", "description": "Appointment time (e.g. 10:00 AM)"},
      {"name": "reasonForVisit", "description": "Reason for the medical visit"}
    ],
    "api_endpoints": [
      {"name": "Create Appointment", "method": "POST", "description": "POST /appointments"},
      {"name": "Get Appointment", "method": "GET", "description": "GET /appointments?contactNumber=..."},
      {"name": "Update Appointment", "method": "PUT", "description": "PUT /appointments/{id}"},
      {"name": "Delete Appointment", "method": "DELETE", "description": "DELETE /appointments/{id}"}
    ],
    "validation_rules": [
      {"entity": "contactNumber", "rule": "numeric", "description": "Must be exactly 10 digits"},
      {"entity": "patientName", "rule": "full_name", "description": "Must include first and last name"}
    ],
    "faq_topics": [
      "Working hours",
      "Insurance acceptance",
      "Cancellation policy"
    ],
    "submission_instructions": "Provide your bot webhook URL and mockapi.io base URL when submitting."
  },
  "submission_config": {
    "max_attempts": 6,
    "require_evaluator_confirmation": true,
    "allow_evaluator_exception": true,
    "feedback_mode": "immediate"
  },
  "tooltips": [
    { "node_type": "aiassist", "text": "Agent Node — enables LLM-powered entity handling and amendment support." },
    { "node_type": "service", "text": "Service Node — makes API calls (GET, POST, PUT, DELETE) to external services." },
    { "node_type": "entity", "text": "Entity Node — collects a specific piece of information from the user." },
    { "node_type": "message", "text": "Message Node — displays a message to the user." },
    { "node_type": "confirmation", "text": "Confirmation Node — asks the user to confirm before proceeding." },
    { "node_type": "form", "text": "Form Node — collects multiple pieces of information in a structured form." }
  ],
