  "faq_config": {
    "required_faqs": [
      {
        "primary_question": "What is the baggage allowance?",
        "ground_truth_answer": "Economy class allows 1 checked bag of 23 kg and 1 carry-on of 7 kg.",
        "required_keywords": ["baggage", "23 kg", "carry-on"],
        "alternate_questions": [
          "How much luggage can I bring?",
          "What's the weight limit for checked bags?"
        ]
      },
      {
        "primary_question": "Can I change my flight after booking?",
        "ground_truth_answer": "Yes, you can modify your booking by providing your contact number.",
        "required_keywords": ["modify", "change", "contact number"],
        "alternate_questions": [
          "How do I reschedule my flight?",
          "Is it possible to change my travel date?"
        ]
      }
    ],
    "min_alternate_questions": 2,
    "semantic_similarity_threshold": 0.80
  },
  "compliance_checks": [
    {
      "check_id": "compliance_dialoggpt",
      "label": "DialogGPT is enabled",
      "cbm_field": "dialogGPTSettings[0].dialogGPTLLMConfig.enable",
      "required_state": "enabled",
      "critical": true,
      "tooltip": "DialogGPT must be enabled for the Agent Node to function correctly."
    }
  ],
  "scoring_config": {
    "cbm_structural_weight": 0.0,
    "webhook_functional_weight": 0.80,
    "compliance_weight": 0.10,
