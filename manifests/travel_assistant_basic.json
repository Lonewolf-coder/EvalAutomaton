  "assignment_brief": {
    "scenario_title": "Travel Assistant Bot",
    "scenario_description": "Build a conversational bot that allows passengers to book, retrieve, modify, and cancel flight reservations via a Kore.ai XO Platform bot connected to a REST mock API.",
    "what_to_build": [
      "Welcome dialog with a main menu",
      "Book a Flight dialog (collects passenger name, contact number, departure city, destination, travel date, seat preference)",
      "Retrieve Booking dialog (looks up by contact number)",
      "Modify Flight dialog (updates travel date, seat preference, or destination)",
      "Cancel Flight flow (deletes booking by contact number)",
      "FAQ knowledge task covering baggage allowance and flight change policy"
    ],
    "entities_to_collect": [
      {"name": "passengerName", "description": "Passenger full name"},
      {"name": "contactNumber", "description": "10-digit phone number (primary key)"},
      {"name": "departureCity", "description": "City of departure"},
      {"name": "destinationCity", "description": "City of destination"},
      {"name": "travelDate", "description": "Travel date (YYYY-MM-DD)"},
      {"name": "seatPreference", "description": "Seat preference: Window, Aisle, or Middle"}
    ],
    "api_endpoints": [
      {"name": "Create Booking", "method": "POST", "description": "POST /bookings"},
      {"name": "Get Booking", "method": "GET", "description": "GET /bookings?contactNumber=..."},
      {"name": "Update Booking", "method": "PUT", "description": "PUT /bookings/{id}"},
      {"name": "Delete Booking", "method": "DELETE", "description": "DELETE /bookings/{id}"}
    ],
    "validation_rules": [
      {"entity": "contactNumber", "rule": "numeric", "description": "Must be exactly 10 digits"}
    ],
    "faq_topics": [
      "Baggage allowance",
      "Flight change / modification policy"
    ],
    "submission_instructions": "Provide your bot webhook URL and mockapi.io base URL when submitting."
  },
  "submission_config": {
    "max_attempts": 6,
    "require_evaluator_confirmation": true,
    "allow_evaluator_exception": true,
    "feedback_mode": "immediate"
  },
  "tooltips": [
    { "node_type": "aiassist", "text": "Agent Node — enables LLM-powered entity handling and amendment support." },
    { "node_type": "service", "text": "Service Node — makes API calls to external services." },
    { "node_type": "entity", "text": "Entity Node — collects information from the user." },
    { "node_type": "message", "text": "Message Node — displays a message to the user." }
  ],
  "created_by": "GovernIQ Admin",
  "notes": "Travel Assistant Bot basic assessment. Scoring: webhook=0.80 (functional authority), compliance=0.10, faq=0.10, cbm=0.0 (informational only)."
