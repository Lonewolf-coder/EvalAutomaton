{
  "_id": "st-med-001",
  "refId": "ref-med-001",
  "type": "default",
  "appType": "unified",
  "purpose": "customer",
  "defaultLanguage": "en",
  "supportedLanguages": ["en"],
  "environmentVersionInfo": "9.1.7",
  "isSmartAssist": false,
  "isAgentAssist": false,
  "isNLEnabled": true,
  "localeData": {
    "en": {
      "name": "Medical Appointment Bot",
      "description": "A chatbot for booking and managing medical appointments",
      "invocationNames": [],
      "nlpVersion": "v3"
    }
  },
  "dialogGPTSettings": [
    {
      "dialogGPTLLMConfig": {
        "enable": true,
        "defaultModel": "gpt-4",
        "temperature": 0.3
      }
    }
  ],
  "llmConfiguration": [
    {
      "featureList": [
        { "name": "NLPBatchTest", "enabled": true },
        { "name": "Rephrase", "enabled": true }
      ]
    }
  ],
  "customDashboards": [],
  "contentVariables": [],
  "channels": [],
  "botEvents": {},
  "forms": [],
  "patterns": [],
  "mlParams": [],
  "smallTalk": [],
  "strict_pii": false,
  "interruptsEnabled": true,
  "sessionInactiveTime": 900000,
  "dialogs": [
    {
      "_id": "dialog_welcome",
      "localeData": {
        "en": {
          "name": "Welcome",
          "shortDesc": "Welcome dialog"
        }
      },
      "nodes": [
        {
          "nodeId": "node_welcome_msg",
          "type": "message",
          "componentId": "comp_welcome_msg",
          "transitions": []
        }
      ]
    },
    {
      "_id": "dialog_book",
      "localeData": {
        "en": {
          "name": "Book Appointment",
          "shortDesc": "Book a medical appointment"
        }
      },
      "nodes": [
        {
          "nodeId": "node_patient_name",
          "type": "entity",
          "componentId": "comp_patient_name",
          "transitions": [{ "default": "node_contact" }]
        },
        {
          "nodeId": "node_contact",
          "type": "entity",
          "componentId": "comp_contact",
          "transitions": [{ "default": "node_doctor" }]
        },
        {
          "nodeId": "node_doctor",
          "type": "entity",
          "componentId": "comp_doctor",
          "transitions": [{ "default": "node_date" }]
        },
        {
          "nodeId": "node_date",
          "type": "entity",
          "componentId": "comp_date",
          "transitions": [{ "default": "node_time" }]
        },
        {
          "nodeId": "node_time",
          "type": "entity",
          "componentId": "comp_time",
          "transitions": [{ "default": "node_reason" }]
        },
        {
          "nodeId": "node_reason",
          "type": "entity",
          "componentId": "comp_reason",
          "transitions": [{ "default": "node_agent" }]
        },
        {
          "nodeId": "node_agent",
          "type": "aiassist",
          "componentId": "comp_agent",
          "transitions": [{ "default": "node_post" }]
        },
        {
          "nodeId": "node_post",
          "type": "service",
          "componentId": "comp_post",
          "transitions": [{ "default": "node_confirm_msg" }]
        },
        {
          "nodeId": "node_confirm_msg",
          "type": "message",
          "componentId": "comp_confirm_msg",
          "transitions": []
        }
      ]
    },
    {
      "_id": "dialog_get",
      "localeData": {
        "en": {
          "name": "Get Appointment Details",
          "shortDesc": "Retrieve appointment information"
        }
      },
      "nodes": [
        {
          "nodeId": "node_get_contact",
          "type": "entity",
          "componentId": "comp_get_contact",
          "transitions": [{ "default": "node_get_service" }]
        },
        {
          "nodeId": "node_get_service",
          "type": "service",
          "componentId": "comp_get_service",
          "transitions": [{ "default": "node_get_display" }]
        },
        {
          "nodeId": "node_get_display",
          "type": "message",
          "componentId": "comp_get_display",
          "transitions": []
        },
        {
          "nodeId": "node_not_found",
          "type": "message",
          "componentId": "comp_not_found",
          "transitions": []
        }
      ]
    },
    {
      "_id": "dialog_modify",
      "localeData": {
        "en": {
          "name": "Modify Appointment Details",
          "shortDesc": "Modify or cancel an appointment"
        }
      },
      "nodes": [
        {
          "nodeId": "node_mod_contact",
          "type": "entity",
          "componentId": "comp_mod_contact",
          "transitions": [{ "default": "node_mod_get" }]
        },
        {
          "nodeId": "node_mod_get",
          "type": "service",
          "componentId": "comp_mod_get",
          "transitions": [{ "default": "node_mod_field" }]
        },
        {
          "nodeId": "node_mod_field",
          "type": "entity",
          "componentId": "comp_mod_field",
          "transitions": [{ "default": "node_mod_value" }]
        },
        {
          "nodeId": "node_mod_value",
          "type": "entity",
          "componentId": "comp_mod_value",
          "transitions": [{ "default": "node_mod_put" }]
        },
        {
          "nodeId": "node_mod_put",
          "type": "service",
          "componentId": "comp_mod_put",
          "transitions": [{ "default": "node_mod_success" }]
        },
        {
          "nodeId": "node_mod_success",
          "type": "message",
          "componentId": "comp_mod_success",
          "transitions": []
        },
        {
          "nodeId": "node_cancel_delete",
          "type": "service",
          "componentId": "comp_cancel_delete",
          "transitions": [{ "default": "node_cancel_success" }]
        },
        {
          "nodeId": "node_cancel_success",
          "type": "message",
          "componentId": "comp_cancel_success",
          "transitions": []
        }
      ]
    }
  ],
  "dialogComponents": [
    {
      "_id": "comp_welcome_msg",
      "name": "WelcomeMessage",
      "message": [
        {
          "localeData": {
            "en": {
              "text": "Welcome to the Medical Appointment Bot! I can help you with:%0A- Book an appointment%0A- Retrieve appointment details%0A- Modify or cancel appointments"
            }
          }
        }
      ]
    },
    {
      "_id": "comp_patient_name",
      "name": "patientName",
      "entityType": "string",
      "localeData": {
        "en": { "label": "Please provide the patient's full name." }
      }
    },
    {
      "_id": "comp_contact",
      "name": "contactNumber",
      "entityType": "phone",
      "localeData": {
        "en": { "label": "What is the contact phone number?" }
      },
      "validationRules": [
        { "rule": "pattern", "value": "^\\d{10}$" }
      ]
    },
    {
      "_id": "comp_doctor",
      "name": "doctorType",
      "entityType": "list",
      "localeData": {
        "en": { "label": "What type of doctor would you like to see?" }
      }
    },
    {
      "_id": "comp_date",
      "name": "preferredDate",
      "entityType": "date",
      "localeData": {
        "en": { "label": "What is your preferred appointment date?" }
      }
    },
    {
      "_id": "comp_time",
      "name": "preferredTime",
      "entityType": "time",
      "localeData": {
        "en": { "label": "What time would you prefer?" }
      }
    },
    {
      "_id": "comp_reason",
      "name": "reasonForVisit",
      "entityType": "string",
      "localeData": {
        "en": { "label": "What is the reason for your visit?" }
      }
    },
    {
      "_id": "comp_agent",
      "name": "BookingAgent",
      "generativeAI": {
        "dynamicEntityConfig": {
          "systemContext": "Help the user book an appointment with the provided details.",
          "rules": [],
          "dynamicEntities": [],
          "exitScenarios": ["Appointment booked successfully"]
        }
      }
    },
    {
      "_id": "comp_post",
      "name": "CreateBooking",
      "endPoint": {
        "protocol": "https",
        "host": "mockapi.io",
        "path": "/appointments",
        "method": "POST"
      }
    },
    {
      "_id": "comp_confirm_msg",
      "name": "BookingConfirmation",
      "message": [
        {
          "localeData": {
            "en": { "text": "Your appointment has been booked successfully!" }
          }
        }
      ]
    },
    {
      "_id": "comp_get_contact",
      "name": "contactNumber",
      "entityType": "phone",
      "localeData": {
        "en": { "label": "Please provide the contact number associated with your appointment." }
      }
    },
    {
      "_id": "comp_get_service",
      "name": "GetAppointment",
      "endPoint": {
        "protocol": "https",
        "host": "mockapi.io",
        "path": "/appointments",
        "method": "GET"
      }
    },
    {
      "_id": "comp_get_display",
      "name": "DisplayAppointment",
      "message": [
        {
          "localeData": {
            "en": { "text": "Here are your appointment details: Patient: {{response.patientName}}" }
          }
        }
      ]
    },
    {
      "_id": "comp_not_found",
      "name": "NotFoundMessage",
      "message": [
        {
          "localeData": {
            "en": { "text": "Sorry, no appointment was found with that contact number. Please check and try again." }
          }
        }
      ]
    },
    {
      "_id": "comp_mod_contact",
      "name": "contactNumber",
      "entityType": "phone",
      "localeData": {
        "en": { "label": "Please provide the contact number for the appointment you want to modify." }
      }
    },
    {
      "_id": "comp_mod_get",
      "name": "GetForModify",
      "endPoint": {
        "protocol": "https",
        "host": "mockapi.io",
        "path": "/appointments",
        "method": "GET"
      }
    },
    {
      "_id": "comp_mod_field",
      "name": "modifyField",
      "entityType": "list",
      "localeData": {
        "en": { "label": "Which field would you like to modify?" }
      }
    },
    {
      "_id": "comp_mod_value",
      "name": "newValue",
      "entityType": "string",
      "localeData": {
        "en": { "label": "What is the new value?" }
      }
    },
    {
      "_id": "comp_mod_put",
      "name": "UpdateAppointment",
      "endPoint": {
        "protocol": "https",
        "host": "mockapi.io",
        "path": "/appointments/{{appointmentId}}",
        "method": "PUT"
      }
    },
    {
      "_id": "comp_mod_success",
      "name": "ModifySuccess",
      "message": [
        {
          "localeData": {
            "en": { "text": "Your appointment has been updated successfully!" }
          }
        }
      ]
    },
    {
      "_id": "comp_cancel_delete",
      "name": "DeleteAppointment",
      "endPoint": {
        "protocol": "https",
        "host": "mockapi.io",
        "path": "/appointments/{{appointmentId}}",
        "method": "DELETE"
      }
    },
    {
      "_id": "comp_cancel_success",
      "name": "CancelSuccess",
      "message": [
        {
          "localeData": {
            "en": { "text": "Your appointment has been cancelled successfully." }
          }
        }
      ]
    }
  ],
  "knowledgeTasks": [
    {
      "name": "Medical FAQ",
      "faqs": {
        "faqs": [
          {
            "question": "What are your working hours?",
            "answer": [
              {
                "text": "Our clinic is open Monday to Friday from 9 AM to 6 PM, and Saturday from 9 AM to 1 PM. We are closed on Sundays and public holidays.",
                "type": "message",
                "channel": ""
              }
            ],
            "alternateQuestions": [
              { "question": "When is the clinic open?" },
              { "question": "What time do you open and close?" },
              { "question": "What are the operating hours?" }
            ]
          },
          {
            "question": "Do you accept insurance?",
            "answer": [
              {
                "text": "Yes, we accept most major insurance providers including Blue Cross, Aetna, and United Healthcare.",
                "type": "message",
                "channel": ""
              }
            ],
            "alternateQuestions": [
              { "question": "Can I use my health insurance?" },
              { "question": "Which insurance plans do you take?" }
            ]
          },
          {
            "question": "How do I cancel my appointment?",
            "answer": [
              {
                "text": "You can cancel your appointment by providing your contact number. We request at least 24 hours notice.",
                "type": "message",
                "channel": ""
              }
            ],
            "alternateQuestions": [
              { "question": "I need to cancel my visit" },
              { "question": "How to cancel a booking?" }
            ]
          },
          {
            "question": "What should I bring to my appointment?",
            "answer": [
              {
                "text": "Please bring a valid photo ID, your insurance card, any relevant medical records, and a list of current medications.",
                "type": "message",
                "channel": ""
              }
            ],
            "alternateQuestions": [
              { "question": "What do I need for my visit?" },
              { "question": "What documents should I carry?" }
            ]
          }
        ]
      }
    }
  ]
}
